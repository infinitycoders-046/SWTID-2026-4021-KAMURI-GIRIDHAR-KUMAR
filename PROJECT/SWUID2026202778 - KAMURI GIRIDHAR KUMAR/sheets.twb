      <aliases enabled='yes' />
      <column caption='season' datatype='string' name='[Calculation_0825747193548802]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [F5]&#13;&#10;    WHEN &quot;Kharif&quot; THEN &quot;Kharif&quot;&#13;&#10;    WHEN &quot;Rabi&quot; THEN &quot;Rabi&quot;&#13;&#10;    WHEN &quot;Summer&quot; THEN &quot;Summer&quot;&#13;&#10;    WHEN &quot;Autumn&quot; THEN &quot;Autumn&quot;&#13;&#10;    WHEN &quot;Winter&quot; THEN &quot;Winter&quot;&#13;&#10;    ELSE &quot;Whole Year&quot;&#13;&#10;END' />
      </column>
      <column caption='Zero' datatype='integer' name='[Calculation_0825747198783491]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='unit types' datatype='string' name='[Calculation_0825747199254532]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Production Units] = &quot;Tonnes&quot; THEN &quot; Bales&quot;&#13;&#10;ELSEIF [Production Units] = &quot;Bales&quot; THEN &quot; Nuts&quot;&#13;&#10;ELSEIF [Production Units] = &quot;Nuts&quot; THEN &quot; Tonnes&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
