        <calculation class='tableau' formula='IF INT([Year]) &lt;= 2000 THEN &quot;Kharif&quot;&#13;&#10;ELSEIF INT([Year]) &lt;= 2005 THEN &quot;Rabi&quot;&#13;&#10;ELSEIF INT([Year]) &lt;= 2010 THEN &quot;Summer&quot;&#13;&#10;ELSEIF INT([Year]) &lt;= 2015 THEN &quot;Autumn&quot;&#13;&#10;ELSE &quot;Whole Year&quot;&#13;&#10;END' />
      </column>
      <column caption='zero' datatype='integer' name='[Calculation_0885672624103425]' role='measure' type='quantitative'>
