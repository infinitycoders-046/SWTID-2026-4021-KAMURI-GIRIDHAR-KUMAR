        <calculation class='tableau' formula='IF [Production Units]= &quot;Tonnes&quot; THEN &quot;Weight Based&quot;&#13;&#10;ELSEIF [Production Units] = &quot;Bales&quot; THEN &quot;Bundle Based&quot;ELSEIF [Production Units]= &quot;Nuts&quot; THEN&quot;Count Based&quot;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
