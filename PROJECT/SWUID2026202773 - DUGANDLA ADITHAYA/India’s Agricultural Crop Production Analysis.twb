            <column-instance column='[Calculation_0254551483867155]' derivation='None' name='[none:Calculation_0254551483867155:nk]' pivot='key' type='nominal' />
            <column-instance column='[Production]' derivation='Sum' name='[sum:Production:qk]' pivot='key' type='quantitative' />
