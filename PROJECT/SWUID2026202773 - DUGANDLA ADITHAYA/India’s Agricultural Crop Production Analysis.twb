          <datasource-dependencies datasource='federated.1kygn3g0xlrygt1bcz0xy0vuf0r1'>
            <column caption='Season' datatype='string' name='[Calculation_0254551483867155]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF LEFT([Crop],1)=&quot;R&quot; THEN &quot;Kharif&quot;&#13;&#10;&#13;&#10;ELSEIF LEFT([Crop],1)=&quot;W&quot; THEN &quot;Rabi&quot;&#13;&#10;&#13;&#10;ELSEIF LEFT([Crop],1)=&quot;M&quot; THEN &quot;Summer&quot;&#13;&#10;&#13;&#10;ELSEIF LEFT([Crop],1)=&quot;A&quot; THEN &quot;Autumn&quot;&#13;&#10;&#13;&#10;ELSE &quot;Whole Year&quot;&#13;&#10;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Crop]' role='dimension' type='nominal' />
